cabal-version:      2.4
name:               sabela-notebook
version:            0.1.0.0
synopsis:           Sticky FRP / animation / widget support modules for Sabela notebooks.
description:
    The batteries that ship with every Sabela notebook: a small, heavily
    documented Functional Reactive Programming vocabulary (behaviours and
    events), plus picture and widget helpers, importable directly from notebook
    cells. Designed to be readable by someone new to programming.
license:            BSD-3-Clause
author:             Sabela
build-type:         Simple

library
    default-language: Haskell2010
    hs-source-dirs:   src
    ghc-options:      -Wall
    exposed-modules:
        Sabela.Notebook
        Sabela.Notebook.Anim
        Sabela.Notebook.Behavior
        Sabela.Notebook.Event
        Sabela.Notebook.Frp
        Sabela.Notebook.Picture
    other-modules:
        Sabela.Notebook.Picture.Internal
        Sabela.Notebook.Picture.Svg
    build-depends:    base >= 4 && < 5
