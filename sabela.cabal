                      Sabela.Api,
                      Sabela.Parse.Ast,
                      Sabela.Parse.Ast.Names,
                      Sabela.Parse.Ast.PatNodeBinders,
                      Sabela.Parse.Preprocess
    build-depends:    base >= 4 && < 5,
                      aeson >= 2.0 && < 3,
                      bytestring >= 0.10 && < 0.13,
                      containers >= 0.6.7 && < 0.9,
                      directory >= 1.3 && < 1.4,
                      filepath >= 1.4 && < 1.6,
                      ghc-lib-parser >= 9.6 && < 9.20,
                      ghc-lib-parser-ex >= 9.6 && < 9.20,
                      http-client >= 0.7 && < 0.10,
                      http-types >= 0.12 && < 0.13,
                      uniplate >= 1.6 && < 1.7,
                      scripths >= 0.5.3.0 && < 0.6,
                      stm >= 2.4 && < 3,
                      text >= 1.2 && < 3,
                      time >= 1.9 && < 2
    hs-source-dirs:   src-contract
    if impl(ghc >= 9.6)
        hs-source-dirs:   src-contract-ghc96
    else
        hs-source-dirs:   src-contract-ghc94
    default-language: Haskell2010

