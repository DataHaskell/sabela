cabal-version:      3.0
name:               sabela
version:            0.1.0.0
synopsis:           A reactive notebook environment for Haskell.
description:        Sabela is a web-based reactive notebook for Haskell. Notebooks are
                    plain Markdown files whose code blocks become executable cells,
                    evaluated by a long-lived GHCi subprocess. Editing a cell
                    re-runs the cells that depend on it, and a bundled web IDE
                    (embedded in the executable) provides editing, rich output,
                    and slideshow/dashboard export.
homepage:           https://www.datahaskell.org/
license:            MIT
license-file:       LICENSE
author:             DataHaskell
maintainer:         mschavinda@gmail.com
category:           Development
build-type:         Simple
extra-doc-files:    CHANGELOG.md, README.md
extra-source-files: static/index.html, static/dashboard.html, static/slideshow.html, data/api-reference.txt,
                    static/src/widgets/scatter.js,
                    static/src/widgets/sabela-widgets.js

source-repository head
    type:     git
    location: https://github.com/DataHaskell/sabela

common warnings
    ghc-options: -Wall

-- The shared contract sub-library: the typed wire (ToolName, ToolOutcome,
-- KernelState, CellResult, Output, SessionEvent), Api, and the AST parser.
-- Both lib:sabela and lib:siza-client depend on it, so the client stops
-- dragging the full server dependency set (warp/servant/process).
