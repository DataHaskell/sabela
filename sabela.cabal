                      Sabela.Anthropic.Types.Response,
                      Sabela.Anthropic.Types.Stream,
                      Sabela.AI.Types,
                      Sabela.AI.CellResult,
                      Sabela.AI.KernelState,
                      Sabela.AI.Provenance,
                      Sabela.AI.RepairTrace,
                      Sabela.AI.Output,
                      Sabela.AI.Grammar,
                      Sabela.AI.Grammar.Synth,
                      Sabela.AI.Discover,
                      Sabela.AI.Examples,
                      Sabela.AI.HoleFits,
                      Sabela.AI.HoleRepair,
                      Sabela.AI.Health,
                      Sabela.AI.ModuleResolve,
                      Sabela.AI.Owned,
                      Sabela.AI.PromptCore,
                      Sabela.AI.Repair,
                      Sabela.AI.Salvage,
                      Sabela.AI.Similarity,
                      Sabela.AI.Spine,
                      Sabela.AI.Capabilities.ToolName,
                      Sabela.LLM.Ollama.Client,
                      Sabela.LLM.Ollama,
                      Sabela.LLM.Anthropic.Client,
                      Sabela.LLM.Anthropic,
                      Sabela.LLM.Message,
